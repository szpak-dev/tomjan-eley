---
import Logo from "./Logo.astro";
import LanguageSelector from "./LanguageSelector.astro";
import Socials from "./Socials.astro";
import { miscRepository, translationRepository } from "../../content";
import { makeUrl } from "../../libs/url";

const lang = Astro.params.lang ?? translationRepository.getDefaultLanguage().code;
const t = translationRepository.getTranslator(lang);
const socials = miscRepository.findSocialAccounts();
const distributionUrl = makeUrl(Astro, { targetLocale: lang, path: "/import-and-distribution/" });
---

<header class="ui-header container-fluid px-0">
  <div class="socials-container bg-dark">
    <Socials socials={socials} />
  </div>
  <div class="container d-flex justify-content-between align-items-center py-2">
    <Logo />
    <div class="d-flex align-items-center gap-3">
      <nav class="header-nav d-flex align-items-center">
        <a href={distributionUrl} class="header-nav__link text-decoration-none">
          {t("nav.importDistribution")}
        </a>
      </nav>
      <LanguageSelector />
    </div>
  </div>
</header>
<div class="container-fluid bg-secondary text-center py-1 shadow-sm">
  <span class="header-gray-stripe-label d-block text-white fw-bold py-1">{t("header.grayStripe")}</span>
</div>
